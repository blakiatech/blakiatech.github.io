---
import { InteractiveAvatarStack } from "@/components/ui/InteractiveAvatarStack";
import { ArrowRight } from "lucide-react";
import { cases, people, totalClients } from "@/data/caseStudies";
---

<section
  id="case-studies"
  class="py-12 md:py-24 bg-blakia-bone text-blakia-brown relative overflow-hidden"
>
  <div class="container relative px-4">
    <div class="text-center mb-8 md:mb-16 relative">
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-4 md:mb-6 text-blakia-brown"
      >
        <span class="text-blakia-brown">Casos de Éxito</span>
      </h2>
      <div class="h-1 w-20 bg-blakia-gold rounded-full mx-auto mb-4 md:mb-8"></div>
      <p class="text-base md:text-xl text-blakia-brown/70 max-w-2xl mx-auto px-4">
        Resultados reales de empresas que ya han automatizado su negocio con
        nosotros.
      </p>
    </div>

    <div class="grid gap-6 md:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 mb-12 md:mb-20">
      {
        cases.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block aspect-[4/5] overflow-hidden rounded-2xl md:rounded-3xl bg-white border border-blakia-brown/20 hover:border-blakia-brown/50 transition-all duration-500 hover:-translate-y-2 hover:shadow-xl"
          >
            {/* Imagen de fondo */}
            <img
              src={item.image.src}
              alt={item.title}
              class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-100"
            />

            {/* Overlay de gradiente */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent transition-opacity duration-500" />

            <div class="absolute inset-0 flex flex-col justify-end p-4 md:p-8">
              {/* Métrica Flotante */}
              <div class="absolute top-4 left-4 md:top-6 md:left-6 transform -translate-y-2 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <span class="bg-blakia-gold backdrop-blur-sm px-2 md:px-3 py-1 rounded-full text-[8px] md:text-[10px] font-black uppercase tracking-widest text-blakia-brown shadow-lg">
                  {item.metric}
                </span>
              </div>

              {/* Icono Link */}
              <div class="absolute top-4 right-4 md:top-6 md:right-6">
                <div class="rounded-full bg-white/20 p-1.5 md:p-2 backdrop-blur-md border border-white/10 group-hover:bg-blakia-gold group-hover:border-blakia-gold group-hover:text-blakia-brown text-white transition-all duration-300">
                  <ArrowRight className="size-4 md:size-5 -rotate-45 group-hover:rotate-0 transition-transform duration-300" />
                </div>
              </div>

              {/* Bloque de Texto */}
              <div class="space-y-2 md:space-y-4 relative z-10">
                <div class="space-y-1 md:space-y-2">
                  <span class="text-blakia-gold font-bold text-[8px] md:text-[10px] uppercase tracking-[0.2em] border border-blakia-gold/20 px-1.5 md:px-2 py-0.5 md:py-1 rounded bg-blakia-gold/10">
                    {item.client}
                  </span>
                  <h3 class="text-lg md:text-2xl lg:text-3xl font-bold leading-tight text-white tracking-tight">
                    {item.title}
                  </h3>
                </div>

                <p class="text-xs md:text-sm text-gray-300 leading-relaxed line-clamp-3 transform transition-all duration-500 group-hover:text-white">
                  {item.description}
                </p>

                {/* Tags */}
                <div class="flex flex-wrap gap-1 md:gap-2 pt-1 md:pt-2">
                  {item.tags.map((tag) => (
                    <span class="text-[7px] md:text-[9px] font-bold uppercase tracking-wider text-gray-300 border border-white/10 bg-black/50 px-1.5 md:px-2 py-0.5 md:py-1 rounded group-hover:border-blakia-gold/50 group-hover:text-blakia-gold transition-colors">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div
      class="flex flex-col items-center justify-center space-y-4 md:space-y-6 pt-6 md:pt-8 border-t border-blakia-brown/20"
    >
      <div class="w-full max-w-md">
        <InteractiveAvatarStack
          client:visible
          items={people}
          extraCount={totalClients}
        />
      </div>
      <p class="text-blakia-brown/70 text-xs md:text-sm font-medium">
        Empresas optimizando procesos con <span
          class="text-blakia-brown font-bold">BlakIA</span
        > este mes.
      </p>
    </div>
  </div>
</section>
