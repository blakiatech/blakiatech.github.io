<section
  id="contact"
  class="relative min-h-screen flex items-center overflow-hidden"
>
  <img
    src="/img/claro/FONDO_CONTACTO.jpg"
    alt="Fondo Contacto"
    class="absolute inset-0 h-full w-full object-cover z-0 dark:hidden"
  />
  <img
    src="/img/oscuro/FONDO_CONTACTO_oscuro.jpg"
    alt="Fondo Contacto"
    class="absolute inset-0 h-full w-full object-cover z-0 hidden dark:block"
  />

  <div
    class="absolute bottom-0 left-0 w-full max-w-200 z-10 pointer-events-none hidden md:block"
  >
    <img
      src="/img/claro/JUSTICIA_BEIGE.png"
      class="w-full h-auto object-contain object-bottom dark:hidden"
      alt="Ilustración"
    />
    <img
      src="/img/oscuro/JUSTICIA_OSCURA.png"
      class="w-full h-auto object-contain object-bottom hidden dark:block"
      alt="Ilustración"
    />
  </div>

  <div
    class="container mx-auto px-4 md:px-6 relative z-20 grid grid-cols-1 lg:grid-cols-2 items-center gap-8 md:gap-12"
  >
    <div class="hidden md:block"></div>

    <div class="flex flex-col space-y-4 items-center py-12 md:py-0">
      <div>
        <h2 class="font-hastegi text-4xl sm:text-5xl md:text-6xl text-white dark:text-blakia-bone-dark">
          <span
            class="font-darling text-5xl sm:text-6xl md:text-7xl text-blakia-brown dark:text-white"
            >L</span
          >idera tu evolución
        </h2>
      </div>

      <div class="bg-white dark:bg-blakia-dark p-6 sm:p-8 rounded-2xl shadow-2xl w-full max-w-2xl">
        <div class="text-center mb-4">
          <h3 class="font-hastegi text-4xl sm:text-5xl md:text-6xl dark:text-blakia-bone-dark">
            <span class="font-darling text-5xl sm:text-6xl md:text-7xl dark:text-white">R</span
            >egistro
          </h3>
        </div>

        <form
          class="flex flex-col gap-4 text-sm sm:text-base max-w-4xl mx-auto"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
            <input
              type="text"
              placeholder="Empresa"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
            <input
              type="text"
              placeholder="CIF"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
            <input
              type="text"
              placeholder="Contacto"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
            <input
              type="text"
              placeholder="Cargo"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
            <input
              type="email"
              placeholder="Correo electrónico"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
            <input
              type="tel"
              placeholder="Teléfono"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
            <input
              type="password"
              placeholder="Contraseña"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
            <input
              type="password"
              placeholder="Confirmar contraseña"
              class="bg-transparent border-b border-blakia-brown/30 dark:border-white/30 py-2 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-gray-600 dark:text-white text-center text-sm"
              >Cuéntanos qué necesitas</label
            >
            <textarea
              name="message"
              id="message"
              rows="4"
              class="bg-transparent border border-blakia-brown/30 dark:border-white/30 rounded-lg p-3 outline-none focus:border-blakia-brown dark:focus:border-white w-full"
            ></textarea>
          </div>

          <div>
            <button
              class="btn-principal w-full py-3 rounded-full transition-colors text-base"
            >
              Enviar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
