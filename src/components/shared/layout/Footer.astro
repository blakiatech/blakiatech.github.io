---
import { SOCIAL_LINKS, FOOTER_LINKS, LEGAL_LINKS } from "@/data/links";
---

<footer
  class="relative border-t border-blakia-brown/20 bg-blakia-bone/50 dark:bg-blakia-dark pt-24 pb-12 overflow-hidden"
>
  <div class="container relative z-10 px-6 mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 mb-20">
      <!-- Brand Column -->
      <div class="lg:col-span-5 space-y-8">
        <div class="space-y-4">
          <a
            href="/"
            class="flex items-center space-x-2 hover:opacity-80 transition-opacity"
          >
            <img
              src="/LOGO_BLAKIA_BEIGE_OSCURO-12.svg"
              alt="BlakIA Logo"
              class="h-6 w-auto object-contain rounded-sm dark:hidden"
            />
            <img
              src="/LOGO_BLAKIA_BEIGE_CLARO-12.svg"
              alt="BlakIA Logo"
              class="h-6 w-auto object-contain rounded-sm hidden dark:block"
            />
          </a>
          <p
            class="text-blakia-brown/70 dark:text-white/70 text-base leading-relaxed max-w-md text-balance"
          >
            Impulsamos el futuro de tu negocio integrando soluciones de
            <span class="text-blakia-brown dark:text-white font-medium"
              >Inteligencia Artificial</span
            >
            que optimizan, automatizan y escalan tus operaciones.
          </p>
        </div>

        <!-- Partner Cards Container -->
        <div class="flex flex-wrap items-center gap-2">
          <div
            class="group/card bg-black p-2 rounded-xl border border-transparent hover:border-blakia-brown/20 transition-all duration-300 flex items-center justify-center shadow-sm hover:shadow-lg hover:-translate-y-1"
          >
            <img
              src="/el-patio-completo-logo-negativo.svg"
              alt="El Patio"
              class="h-full w-52 object-contain p-2"
            />
          </div>

          <div
            class="group/card bg-white p-2 rounded-xl border border-blakia-brown/20 hover:border-blakia-brown/30 transition-all duration-300 flex items-center justify-center shadow-sm hover:shadow-lg hover:-translate-y-1"
          >
            <img
              src="/IMDEEC-Pegatinas-2025-Autoempleo-L1.jpg"
              alt="IMDEEC"
              class="h-full w-52 object-contain rounded-lg"
            />
          </div>
        </div>
      </div>

      <!-- Spacer -->
      <div class="hidden lg:block lg:col-span-1"></div>

      <!-- Navigation Columns -->
      <div class="lg:col-span-6 grid grid-cols-2 sm:grid-cols-2 gap-10">
        <div class="space-y-6">
          <h3 class="text-lg font-bold text-blakia-brown dark:text-blakia-bone-dark relative inline-block">
            Explorar
            <span
              class="absolute -bottom-2 left-0 w-8 h-1 bg-blakia-brown dark:bg-blakia-bone-dark rounded-full"
            ></span>
          </h3>
          <ul class="space-y-4">
            {
              FOOTER_LINKS.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-blakia-brown/70 dark:text-white/70 hover:text-blakia-brown dark:hover:text-white transition-colors hover:translate-x-1 inline-block duration-200"
                  >
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-6">
          <h3 class="text-lg font-bold text-blakia-brown dark:text-blakia-bone-dark relative inline-block">
            Legal
            <span
              class="absolute -bottom-2 left-0 w-8 h-1 bg-blakia-brown dark:bg-blakia-bone-dark rounded-full"
            ></span>
          </h3>
          <ul class="space-y-4">
            {
              LEGAL_LINKS.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-blakia-brown/70 dark:text-white/70 hover:text-blakia-brown dark:hover:text-white transition-colors hover:translate-x-1 inline-block duration-200"
                  >
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div
      class="border-t border-blakia-brown/20 dark:border-blakia-white/20 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-blakia-brown/70 dark:text-blakia-white/70"
    >
      <p class="flex items-center gap-1">
        &copy; {new Date().getFullYear()}
        <span class="font-bold text-blakia-brown dark:text-white">BlakIA</span>. Todos los
        derechos reservados.
      </p>
      <div>
        <div class={`flex gap-4`}>
          {
            SOCIAL_LINKS.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class="text-blakia-brown/70 dark:text-blakia-white/70 hover:text-blakia-brown dark:hover:text-white-brown hover:bg-blakia-brown/10 dark:hover:bg-white/10 transition-colors p-2 rounded-full"
              >
                <span class="sr-only">{link.name}</span>
                <link.icon className="h-5 w-5" />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
