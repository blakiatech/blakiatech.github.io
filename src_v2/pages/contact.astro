---
import PageLayout from "@/layouts/PageLayout.astro";
import { ContactForm } from "@/components/sections/contact/Contact_Form";
import GridPattern from "@/components/ui/GridPattern.astro";
---

<PageLayout title="Contacto | BlakIA" description="Hablemos de tu proyecto de automatización.">
  <div class="relative min-h-screen pt-20 overflow-hidden flex items-center justify-center bg-background dark:bg-zinc-950 transition-colors duration-300">
    {/* Global Grid Pattern */}
    {/* The Monumental Form Component */}
    <div class="w-full animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-200">
        <ContactForm client:load />
    </div>
  </div>
</PageLayout>